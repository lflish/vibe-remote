{
  "name": "ccdesk",
  "version": "0.1.0",
  "description": "Remote Claude terminal manager",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "start": "electron dist/main/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0"
  },
  "build": {
    "appId": "com.ccdesk.app",
    "productName": "ccdesk",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "dist/**/*"
    ]
  }
}
